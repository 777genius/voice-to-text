{
  "name": "voice-to-text",
  "version": "0.16.1",
  "type": "module",
  "description": "Privacy-focused voice-to-text application with offline support",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run && npm run --silent test:e2e-helpers",
    "test:coverage": "vitest run --coverage",
    "test:e2e-helpers": "node --test e2e-tests/helpers/liveAudioEvidenceContract.test.mjs e2e-tests/helpers/liveAudioRunner.test.mjs e2e-tests/helpers/processUtils.test.mjs e2e-tests/helpers/tauriE2e.test.mjs",
    "typecheck": "vue-tsc --noEmit",
    "release:notes": "node scripts/prepare-release-notes.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:build": "tauri build",
    "tauri:dev:prod-backend": "VITE_API_URL=https://api.voicetext.site VOICE_TO_TEXT_API_URL=https://api.voicetext.site VOICE_TO_TEXT_BACKEND_URL=wss://api.voicetext.site tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:dev:whisper": "tauri dev --config src-tauri/tauri.dev.conf.json --features whisper",
    "tauri:build:whisper": "tauri build --features whisper",
    "e2e:tauri": "node e2e-tests/run-e2e.mjs",
    "e2e:live-audio": "node e2e-tests/run-live-audio-smoke.mjs",
    "e2e:live-audio-soak": "node e2e-tests/run-live-audio-soak.mjs"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@statesync/core": "^1.1.0",
    "@statesync/pinia": "^2.0.0",
    "@statesync/tauri": "^2.0.0",
    "pinia": "^2.1.0",
    "refresh-fetch": "^0.9.0",
    "vue": "^3.4.0",
    "vue-i18n": "^11.2.8",
    "vuetify": "^3.7.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.0.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.0.0",
    "@tauri-apps/plugin-deep-link": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.17",
    "@wdio/cli": "^9.19.0",
    "@wdio/local-runner": "^9.19.0",
    "@wdio/mocha-framework": "^9.19.0",
    "@wdio/spec-reporter": "^9.19.0",
    "expect-webdriverio": "^5.4.0",
    "jsdom": "^27.4.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vite-plugin-vuetify": "^2.0.4",
    "vitest": "^4.0.17",
    "vue-tsc": "^3.1.0",
    "webdriverio": "^9.19.0"
  }
}
